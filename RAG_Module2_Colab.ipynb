        "    print('\\n📌 Sources used:')\n",
        "    for doc in result['source_documents']:\n",
        "        page = doc.metadata.get('page', '?')\n",
        "        print(f'  • Page {page}: {doc.page_content[:120]}...')\n",
        "    print('=' * 60)\n",
